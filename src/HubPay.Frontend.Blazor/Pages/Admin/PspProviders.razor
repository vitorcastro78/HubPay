@page "/admin/psp"
@using HubPay.Application.DTOs.Admin
@inject HubPay.Frontend.Blazor.Services.HubPayApiClient Api

<PageTitle>Admin PSP — HubPay</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Configuração PSP</h1>
    <div>
        <button class="btn btn-warning mr-2" disabled="@_busy" @onclick="ReloadAsync">
            <i class="fas fa-sync"></i> Recarregar em memória
        </button>
        <a class="btn btn-primary" href="admin/psp/new">
            <i class="fas fa-plus"></i> Novo PSP
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_messageError ? "alert-danger" : "alert-success") alert-dismissible">
        @_message
        <button type="button" class="close" @onclick="() => _message = null"><span>&times;</span></button>
    </div>
}

@if (_loading)
{
    <p><i class="fas fa-spinner fa-spin"></i> A carregar...</p>
}
else
{
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Provedores PSP</h3>
            <a class="btn btn-sm btn-outline-secondary float-right" href="admin/psp-merchants">Config. Merchants</a>
        </div>
        <div class="card-body table-responsive p-0">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Scheme</th>
                        <th>Ativo</th>
                        <th>Atualizado</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _providers)
                    {
                        <tr>
                            <td><strong>@p.Scheme</strong></td>
                            <td>
                                @if (p.IsEnabled)
                                {
                                    <span class="badge badge-success">Sim</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Não</span>
                                }
                            </td>
                            <td>@p.UpdatedAt.ToLocalTime().ToString("g")</td>
                            <td class="text-right">
                                <a class="btn btn-sm btn-info" href="@($"admin/psp/{p.Scheme}")">Editar</a>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteAsync(p.Scheme)">Apagar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<PspProviderConfigDto> _providers = [];
    private bool _loading = true;
    private bool _busy;
    private string? _message;
    private bool _messageError;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _providers = (await Api.GetPspProvidersAsync())?.ToList() ?? [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ReloadAsync()
    {
        _busy = true;
        _message = null;
        try
        {
            var result = await Api.ReloadPspConfigurationAsync();
            if (result is null)
            {
                _messageError = true;
                _message = "Falha ao recarregar configurações.";
            }
            else
            {
                _messageError = false;
                _message = result.Message;
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteAsync(string scheme)
    {
        if (await Api.DeletePspProviderAsync(scheme))
        {
            _messageError = false;
            _message = $"{scheme} removido.";
            await LoadAsync();
        }
        else
        {
            _messageError = true;
            _message = "Não foi possível apagar.";
        }
    }
}
