@inherits LayoutComponentBase

<div class="wrapper">
    <nav class="main-header navbar navbar-expand navbar-white navbar-light border-bottom">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
            </li>
            <li class="nav-item d-none d-sm-inline-block">
                <span class="nav-link font-weight-bold">HubPay Pan-EU</span>
            </li>
        </ul>
    </nav>

    <aside class="main-sidebar sidebar-dark-primary elevation-4">
        <a href="/" class="brand-link">
            <span class="brand-text font-weight-light ml-3">HubPay PSD3</span>
        </a>
        <div class="sidebar">
            <nav class="mt-2">
                <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                            <i class="nav-icon fas fa-tachometer-alt"></i>
                            <p>Dashboard</p>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="transactions">
                            <i class="nav-icon fas fa-exchange-alt"></i>
                            <p>Transações EU</p>
                        </NavLink>
                    </li>
                    <li class="nav-header">Administração</li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="admin/psp">
                            <i class="nav-icon fas fa-cogs"></i>
                            <p>Configuração PSP</p>
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="admin/psp-merchants">
                            <i class="nav-icon fas fa-store"></i>
                            <p>PSP por Merchant</p>
                        </NavLink>
                    </li>
                </ul>
            </nav>
        </div>
    </aside>

    <div class="content-wrapper">
        <section class="content pt-3">
            <div class="container-fluid">
                @Body
            </div>
        </section>
    </div>

    <footer class="main-footer">
        <strong>HubPay</strong> — Middleware IA Anti-fraude inline
    </footer>
</div>
