{
  "HubPay": {
    "ConnectionString": "Host=localhost;Port=5432;Database=hubpay;Username=postgres;Password=postgres",
    "RedisConnectionString": "localhost:6379",
    "OnnxModelPath": "Models/antifraud.onnx",
    "HubProcessingFeePercent": 0.8,
    "IdempotencyTtlHours": 24,
    "ClearingIntervalSeconds": 30,
    "ApplyMigrationsOnStartup": true,
    "LoadPspConfigurationFromDatabase": true,
    "RequireMutualTlsInProduction": true,
    "Jwt": {
      "Issuer": "https://hubpay.eu",
      "Audience": "hubpay-api",
      "SecretKey": "DEV_ONLY_CHANGE_IN_PRODUCTION_MIN_32_CHARS!!",
      "ExpirationMinutes": 60
    },
    "Webhooks": {
      "SignatureHeaderName": "X-HubPay-Signature",
      "SchemeSecrets": {
        "MBWAY": "",
        "MULTIBANCO": "",
        "BIZUM": "",
        "WERO": "",
        "EURO6000": "",
        "CARTESBANCAIRES": "",
        "IDEAL": "",
        "BANCONTACT": "",
        "BANCOMATPAY": "",
        "SWISH": "",
        "VIPPSMOBILEPAY": "",
        "DEFAULT": ""
      }
    },
    "Camt053": {
      "InboundDirectory": "data/camt053/inbound",
      "ProcessedDirectory": "data/camt053/processed",
      "UseSimulatedStatementsWhenEmpty": false
    },
    "Sibs": {
      "BaseUrl": "https://api.sibs.pt",
      "ApiKey": "",
      "ClientId": "",
      "MerchantId": "",
      "WebhookBaseUrl": "https://api.hubpay.eu",
      "EnableSimulationFallback": false,
      "DefaultMultibancoEntity": "11683",
      "MerchantMultibancoEntities": {},
      "MbWayInitPath": "/v1/mbway/payments",
      "MultibancoInitPath": "/v1/multibanco/references",
      "RefundPath": "/v1/payments/{paymentId}/refunds",
      "MutualTls": {
        "Enabled": true,
        "ClientCertificatePath": "certificates/sibs/client.pfx",
        "ClientCertificatePasswordEnvironmentVariable": "HUBPAY_SIBS_CERT_PASSWORD",
        "CaCertificatePath": "certificates/sibs/ca.crt",
        "ValidateServerCertificate": true
      }
    },
    "Bizum": {
      "BaseUrl": "https://api.bizum.es",
      "ApiKey": "",
      "ClientId": "",
      "EnableSimulationFallback": false,
      "PaymentInitPath": "/v1/payments",
      "RefundPath": "/v1/payments/{paymentId}/refunds",
      "MutualTls": {
        "Enabled": true,
        "ClientCertificatePath": "certificates/bizum/client.pfx",
        "ClientCertificatePasswordEnvironmentVariable": "HUBPAY_BIZUM_CERT_PASSWORD",
        "CaCertificatePath": "certificates/bizum/ca.crt"
      }
    },
    "Wero": {
      "BaseUrl": "https://api.wero.eu",
      "ApiKey": "",
      "ClientId": "",
      "EnableSimulationFallback": false,
      "InstantPaymentPath": "/v1/instant-payments",
      "RefundPath": "/v1/instant-payments/{paymentId}/refunds",
      "DefaultDebtorIban": "",
      "DefaultCreditorIban": "",
      "MerchantAccounts": {},
      "MutualTls": {
        "Enabled": true,
        "ClientCertificatePath": "certificates/wero/client.pfx",
        "ClientCertificatePasswordEnvironmentVariable": "HUBPAY_WERO_CERT_PASSWORD",
        "CaCertificatePath": "certificates/wero/ca.crt"
      }
    },
    "CartesBancaires": {
      "BaseUrl": "https://api.cartesbancaires.fr",
      "ApiKey": "",
      "EnableSimulationFallback": false,
      "AuthorizePath": "/v1/payments/authorize",
      "ThreeDsStatusPath": "/v1/payments/{paymentId}/3ds/status",
      "MutualTls": {
        "Enabled": true,
        "ClientCertificatePath": "certificates/cartesbancaires/client.pfx",
        "ClientCertificatePasswordEnvironmentVariable": "HUBPAY_CB_CERT_PASSWORD"
      }
    },
    "Ideal": {
      "BaseUrl": "https://api.ideal.nl/v2",
      "EnableSimulationFallback": false,
      "MutualTls": {
        "Enabled": true,
        "ClientCertificatePath": "certificates/ideal/client.pfx",
        "ClientCertificatePasswordEnvironmentVariable": "HUBPAY_IDEAL_CERT_PASSWORD"
      }
    },
    "Bancontact": {
      "BaseUrl": "https://api.bancontact.com/v1",
      "EnableSimulationFallback": false,
      "MutualTls": {
        "Enabled": true,
        "ClientCertificatePath": "certificates/bancontact/client.pfx",
        "ClientCertificatePasswordEnvironmentVariable": "HUBPAY_BANCONTACT_CERT_PASSWORD"
      }
    },
    "Euro6000": {
      "BaseUrl": "https://api.euro6000.es/v1",
      "EnableSimulationFallback": false,
      "MutualTls": {
        "Enabled": true,
        "ClientCertificatePath": "certificates/euro6000/client.pfx",
        "ClientCertificatePasswordEnvironmentVariable": "HUBPAY_EURO6000_CERT_PASSWORD"
      }
    },
    "BancomatPay": {
      "BaseUrl": "https://api.bancomatpay.it/v1",
      "EnableSimulationFallback": false,
      "MutualTls": {
        "Enabled": true,
        "ClientCertificatePath": "certificates/bancomatpay/client.pfx",
        "ClientCertificatePasswordEnvironmentVariable": "HUBPAY_BANCOMATPAY_CERT_PASSWORD"
      }
    },
    "Swish": {
      "BaseUrl": "https://api.swish.nu/v2",
      "EnableSimulationFallback": false,
      "MutualTls": {
        "Enabled": true,
        "ClientCertificatePath": "certificates/swish/client.pfx",
        "ClientCertificatePasswordEnvironmentVariable": "HUBPAY_SWISH_CERT_PASSWORD"
      }
    },
    "VippsMobilePay": {
      "BaseUrl": "https://api.vipps.no/v1",
      "EnableSimulationFallback": false,
      "MutualTls": {
        "Enabled": true,
        "ClientCertificatePath": "certificates/vipps/client.pfx",
        "ClientCertificatePasswordEnvironmentVariable": "HUBPAY_VIPPS_CERT_PASSWORD"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
